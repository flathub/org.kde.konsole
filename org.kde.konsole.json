{
    "id": "org.kde.konsole",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "sdk": "org.kde.Sdk",
    "command": "konsole",
    "rename-icon": "utilities-terminal",
    "finish-args": [
        "--device=dri",
        "--share=ipc",
        "--share=network",
        "--socket=wayland",
        "--socket=fallback-x11",
        "--talk-name=org.freedesktop.Flatpak"
    ],
    "cleanup": [
        "/share/doc",
        "/share/qlogging-categories6"
    ],
    "modules": [
        {
            "name": "konsole",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DINSTALL_ICONS=ON"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/release-service/26.04.1/src/konsole-26.04.1.tar.xz",
                    "sha256": "4c59dabc4b64201c61458e8997a66d1aa7dc98b181e5e85f3c0f5cb69066d963",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 8763,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/stable/release-service/$version/src/konsole-$version.tar.xz"
                    }
                }
            ]
        }
    ]
}
